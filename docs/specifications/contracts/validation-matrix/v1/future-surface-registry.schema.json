{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local-agent-monitor.invalid/contracts/validation-matrix/v1/future-surface-registry.schema.json",
  "title": "Future validation surface registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "entries"],
  "properties": {
    "$schema": { "const": "future-surface-registry.schema.json" },
    "schema_version": { "const": "validation-future-surfaces.v1" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["surface_id", "title", "owner_issue", "state", "entry_condition", "required_profiles", "expected_evidence_location"],
        "properties": {
          "surface_id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "title": { "type": "string", "minLength": 1 },
          "owner_issue": { "type": "integer", "minimum": 1 },
          "state": { "const": "not_available" },
          "entry_condition": { "type": "string", "minLength": 1 },
          "required_profiles": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "expected_evidence_location": { "type": "string", "pattern": "^docs/sprints/" }
        }
      }
    }
  }
}
