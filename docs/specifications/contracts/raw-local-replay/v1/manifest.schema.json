{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local-agent-monitor.invalid/contracts/raw-local-replay/v1/manifest.schema.json",
  "title": "Raw local replay manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "bundle_schema_version", "profile",
    "canonical_json_version", "archive_version", "checksum_version",
    "data_classification", "created_at", "snapshot_id", "local_monitor_version",
    "raw_record_count", "session_content_count", "start_inclusive", "end_exclusive",
    "source_versions", "content_states", "secret_filter_states", "known_missing",
    "normalization_version", "projection_version", "dashboard_version",
    "expected_normalized_sha256", "expected_projection_sha256",
    "expected_dashboard_sha256", "files"
  ],
  "properties": {
    "schema_version": { "const": "raw-local-replay-manifest.v1" },
    "bundle_schema_version": { "const": "raw-local-replay-bundle.v1" },
    "profile": { "const": "raw-local-replay" },
    "canonical_json_version": { "const": "raw-local-replay-canonical-json.v1" },
    "archive_version": { "const": "raw-local-replay-zip-store.v1" },
    "checksum_version": { "const": "sha256.v1" },
    "data_classification": { "const": "raw" },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "snapshot_id": { "$ref": "#/$defs/identifier" },
    "local_monitor_version": { "$ref": "#/$defs/identifier" },
    "raw_record_count": { "type": "integer", "minimum": 0, "maximum": 255 },
    "session_content_count": { "type": "integer", "minimum": 0, "maximum": 255 },
    "start_inclusive": {
      "oneOf": [{ "$ref": "#/$defs/timestamp" }, { "type": "null" }]
    },
    "end_exclusive": {
      "oneOf": [{ "$ref": "#/$defs/timestamp" }, { "type": "null" }]
    },
    "source_versions": { "$ref": "#/$defs/string_array" },
    "content_states": { "$ref": "#/$defs/string_array" },
    "secret_filter_states": { "$ref": "#/$defs/string_array" },
    "known_missing": { "$ref": "#/$defs/missing_code_array" },
    "normalization_version": { "const": "raw-measurement-normalization.v1" },
    "projection_version": { "const": "raw-replay-monitor-projection.v1" },
    "dashboard_version": { "const": "raw-replay-dashboard.v1" },
    "expected_normalized_sha256": { "$ref": "#/$defs/sha256" },
    "expected_projection_sha256": { "$ref": "#/$defs/sha256" },
    "expected_dashboard_sha256": { "$ref": "#/$defs/sha256" },
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 255,
      "items": { "$ref": "#/$defs/file" }
    }
  },
  "$defs": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{7}Z$"
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[^\\x00-\\x1f\\x7f/\\\\?#]+$"
    },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "string_array": {
      "type": "array",
      "maxItems": 255,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1536,
        "pattern": "^[^\\x00-\\x1f\\x7f]+$"
      }
    },
    "missing_code_array": {
      "type": "array",
      "maxItems": 255,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "pattern": "^[a-z0-9_]+$"
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind", "size", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(records/record-[0-9]{6}|session-content/content-[0-9]{6})\\.json$"
        },
        "kind": { "enum": ["raw_record", "session_event_content"] },
        "size": { "type": "integer", "minimum": 1, "maximum": 31457280 },
        "sha256": { "$ref": "#/$defs/sha256" }
      },
      "oneOf": [
        {
          "properties": {
            "path": { "pattern": "^records/record-[0-9]{6}\\.json$" },
            "kind": { "const": "raw_record" },
            "size": { "maximum": 31457280 }
          }
        },
        {
          "properties": {
            "path": { "pattern": "^session-content/content-[0-9]{6}\\.json$" },
            "kind": { "const": "session_event_content" },
            "size": { "maximum": 8388608 }
          }
        }
      ]
    }
  }
}
