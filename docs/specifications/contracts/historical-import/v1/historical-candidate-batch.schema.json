{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.copilot-agent-observability.invalid/contracts/historical-import/v1/historical-candidate-batch.schema.json",
  "title": "Historical candidate batch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "fixture_only_not_source_support_evidence",
    "profile_id",
    "adapter_id",
    "source_surface",
    "source_tier",
    "source_application_version",
    "source_format_name",
    "source_format_version",
    "source_fixture_sha256",
    "source_schema_fingerprint",
    "normalization_version",
    "completeness_ceiling",
    "candidates"
  ],
  "properties": {
    "contract_version": { "const": "historical-candidate-batch/v1" },
    "fixture_only_not_source_support_evidence": { "type": "boolean" },
    "profile_id": { "$ref": "#/$defs/token" },
    "adapter_id": { "$ref": "#/$defs/token" },
    "source_surface": { "enum": ["claude-code", "github-copilot-cli"] },
    "source_tier": { "const": "tier_b" },
    "source_application_version": { "$ref": "#/$defs/version" },
    "source_format_name": { "$ref": "#/$defs/token" },
    "source_format_version": { "$ref": "#/$defs/version" },
    "source_fixture_sha256": { "$ref": "#/$defs/sha256" },
    "source_schema_fingerprint": { "$ref": "#/$defs/fingerprint" },
    "normalization_version": { "$ref": "#/$defs/token" },
    "completeness_ceiling": { "const": "partial" },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": { "$ref": "#/$defs/candidate" }
    }
  },
  "$defs": {
    "token": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$(?![\\s\\S])"
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$(?![\\s\\S])"
    },
    "sha256": { "type": "string", "minLength": 64, "maxLength": 64, "pattern": "^[a-f0-9]{64}$" },
    "fingerprint": { "type": "string", "minLength": 71, "maxLength": 71, "pattern": "^sha256:[a-f0-9]{64}$" },
    "field": {
      "type": "string",
      "enum": [
        "model_tokens.model",
        "model_tokens.input_tokens",
        "model_tokens.output_tokens",
        "model_tokens.total_tokens",
        "model_tokens.cache_tokens",
        "model_tokens.reasoning_tokens",
        "retry_attempt.retry",
        "retry_attempt.attempt",
        "errors.present",
        "errors.code"
      ]
    },
    "values": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "model_tokens": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "model": { "type": "string", "minLength": 1 },
            "input_tokens": { "type": "integer", "minimum": 0 },
            "output_tokens": { "type": "integer", "minimum": 0 },
            "total_tokens": { "type": "integer", "minimum": 0 },
            "cache_tokens": { "type": "integer", "minimum": 0 },
            "reasoning_tokens": { "type": "integer", "minimum": 0 }
          }
        },
        "retry_attempt": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "retry": { "type": "boolean" },
            "attempt": { "type": "integer", "minimum": 0 }
          }
        },
        "errors": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "present": { "type": "boolean" },
            "code": { "type": ["string", "null"], "minLength": 1 }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "adapter_id",
        "source_surface",
        "source_application_version",
        "source_format_name",
        "source_format_version",
        "source_fixture_sha256",
        "source_schema_fingerprint",
        "source_record_key",
        "capture_content_state",
        "normalization_version"
      ],
      "properties": {
        "field": { "$ref": "#/$defs/field" },
        "adapter_id": { "$ref": "#/$defs/token" },
        "source_surface": { "enum": ["claude-code", "github-copilot-cli"] },
        "source_application_version": { "$ref": "#/$defs/version" },
        "source_format_name": { "$ref": "#/$defs/token" },
        "source_format_version": { "$ref": "#/$defs/version" },
        "source_fixture_sha256": { "$ref": "#/$defs/sha256" },
        "source_schema_fingerprint": { "$ref": "#/$defs/fingerprint" },
        "source_record_key": { "$ref": "#/$defs/sourceRecordKey" },
        "capture_content_state": { "enum": ["available", "not_captured", "redacted", "unsupported"] },
        "normalization_version": { "$ref": "#/$defs/token" }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_key", "source_record_key", "values", "completeness", "completeness_reasons", "field_provenance"],
      "properties": {
        "candidate_key": { "$ref": "#/$defs/candidateKey" },
        "source_record_key": { "$ref": "#/$defs/sourceRecordKey" },
        "values": { "$ref": "#/$defs/values" },
        "completeness": { "const": "partial" },
        "completeness_reasons": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "items": { "const": "historical_summary_only" }
        },
        "field_provenance": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/provenance" }
        }
      }
    },
    "candidateKey": {
      "type": "string",
      "minLength": 35,
      "maxLength": 35,
      "pattern": "^hc_[a-f0-9]{32}$"
    },
    "sourceRecordKey": {
      "type": "string",
      "minLength": 35,
      "maxLength": 35,
      "pattern": "^hr_[a-f0-9]{32}$"
    }
  }
}
