{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.copilot-agent-observability.invalid/contracts/historical-import-workflow/v1/confirmation.schema.json",
  "title": "Historical import confirmation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "schema_version",
    "confirmation_id",
    "preview_id",
    "preview_digest",
    "snapshot_version",
    "eligibility",
    "decision",
    "expires_after_seconds"
  ],
  "properties": {
    "contract_version": { "const": "historical-import-workflow/v1" },
    "schema_version": { "const": "historical-import-workflow-confirmation/v1" },
    "confirmation_id": { "type": "string", "minLength": 36, "maxLength": 36, "pattern": "^hic_[0-9a-f]{32}$" },
    "preview_id": { "type": "string", "minLength": 36, "maxLength": 36, "pattern": "^hip_[0-9a-f]{32}$" },
    "preview_digest": { "type": "string", "minLength": 71, "maxLength": 71, "pattern": "^sha256:[0-9a-f]{64}$" },
    "snapshot_version": { "type": "string", "minLength": 5, "pattern": "^hsv_[1-9][0-9]*$(?![\\s\\S])" },
    "eligibility": { "const": "eligible" },
    "decision": { "const": "confirm" },
    "expires_after_seconds": { "type": "integer", "minimum": 1, "maximum": 300 }
  }
}
