{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.copilot-agent-observability.invalid/contracts/historical-import-workflow/v1/import-result.schema.json",
  "title": "Historical import operation result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "schema_version",
    "operation_id",
    "request_id",
    "preview_id",
    "preview_digest",
    "snapshot_version",
    "outcome",
    "transaction_outcome",
    "idempotency_outcome",
    "source_kind",
    "source_surface",
    "source_tier",
    "profile_id",
    "adapter_id",
    "evidence_status",
    "counts",
    "observations",
    "duplicates",
    "conflicts",
    "retention"
  ],
  "properties": {
    "contract_version": { "const": "historical-import-workflow/v1" },
    "schema_version": { "const": "historical-import-workflow-import-result/v1" },
    "operation_id": { "type": "string", "minLength": 36, "maxLength": 36, "pattern": "^hop_[0-9a-f]{32}$" },
    "request_id": { "type": "string", "minLength": 36, "maxLength": 36, "pattern": "^hir_[0-9a-f]{32}$" },
    "preview_id": { "type": "string", "minLength": 36, "maxLength": 36, "pattern": "^hip_[0-9a-f]{32}$" },
    "preview_digest": { "$ref": "#/$defs/digest" },
    "snapshot_version": { "type": "string", "minLength": 5, "pattern": "^hsv_[1-9][0-9]*$(?![\\s\\S])" },
    "outcome": { "const": "succeeded" },
    "transaction_outcome": { "const": "committed" },
    "idempotency_outcome": { "enum": ["first_application", "replayed"] },
    "source_kind": { "const": "historical" },
    "source_surface": { "enum": ["claude-code", "github-copilot-cli"] },
    "source_tier": { "const": "tier_b" },
    "profile_id": { "$ref": "#/$defs/token" },
    "adapter_id": { "$ref": "#/$defs/token" },
    "evidence_status": { "const": "production" },
    "counts": { "$ref": "#/$defs/counts" },
    "observations": { "type": "array", "maxItems": 1000, "uniqueItems": true, "items": { "$ref": "#/$defs/observation" } },
    "duplicates": { "type": "array", "maxItems": 1000, "uniqueItems": true, "items": { "$ref": "#/$defs/duplicate" } },
    "conflicts": { "type": "array", "maxItems": 1000, "uniqueItems": true, "items": { "$ref": "#/$defs/conflict" } },
    "retention": { "$ref": "#/$defs/retention" }
  },
  "$defs": {
    "digest": { "type": "string", "minLength": 71, "maxLength": 71, "pattern": "^sha256:[0-9a-f]{64}$" },
    "observation_id": { "type": "string", "minLength": 36, "maxLength": 36, "pattern": "^hob_[0-9a-f]{32}$" },
    "record_result_id": { "type": "string", "minLength": 36, "maxLength": 36, "pattern": "^hrr_[0-9a-f]{32}$" },
    "token": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$(?![\\s\\S])"
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "new_observations", "new_sessions", "new_events", "duplicates", "conflicts", "record_rejections"],
      "properties": {
        "total": { "$ref": "#/$defs/positive_available_count" },
        "new_observations": { "$ref": "#/$defs/available_count" },
        "new_sessions": { "$ref": "#/$defs/unavailable_count" },
        "new_events": { "$ref": "#/$defs/unavailable_count" },
        "duplicates": { "$ref": "#/$defs/available_count" },
        "conflicts": { "$ref": "#/$defs/available_count" },
        "record_rejections": { "$ref": "#/$defs/available_count" }
      }
    },
    "available_count": {
      "type": "object",
      "additionalProperties": false,
      "required": ["availability", "value"],
      "properties": {
        "availability": { "const": "available" },
        "value": { "type": "integer", "minimum": 0, "maximum": 1000 }
      }
    },
    "positive_available_count": {
      "type": "object",
      "additionalProperties": false,
      "required": ["availability", "value"],
      "properties": {
        "availability": { "const": "available" },
        "value": { "type": "integer", "minimum": 1, "maximum": 1000 }
      }
    },
    "unavailable_count": {
      "type": "object",
      "additionalProperties": false,
      "required": ["availability", "value"],
      "properties": {
        "availability": { "const": "unavailable" },
        "value": { "const": null }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observation_id",
        "identity_resolution",
        "binding_basis",
        "completeness",
        "completeness_reasons",
        "missing_capabilities",
        "content_state"
      ],
      "properties": {
        "observation_id": { "$ref": "#/$defs/observation_id" },
        "identity_resolution": { "enum": ["distinct_unbound", "attached_exact"] },
        "binding_basis": { "enum": ["none", "native_id", "explicit_link", "exact_trace_id"] },
        "completeness": { "const": "partial" },
        "completeness_reasons": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "uniqueItems": true,
          "items": { "const": "historical_summary_only" }
        },
        "missing_capabilities": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "uniqueItems": true,
          "items": { "enum": ["content", "event_identity", "lifecycle", "session_identity", "timing", "trace_identity"] }
        },
        "content_state": { "const": "not_captured" }
      },
      "oneOf": [
        {
          "properties": {
            "identity_resolution": { "const": "distinct_unbound" },
            "binding_basis": { "const": "none" }
          }
        },
        {
          "properties": {
            "identity_resolution": { "const": "attached_exact" },
            "binding_basis": { "enum": ["native_id", "explicit_link", "exact_trace_id"] }
          }
        }
      ]
    },
    "duplicate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_result_id", "observation_id", "candidate_fingerprint", "decision"],
      "properties": {
        "record_result_id": { "$ref": "#/$defs/record_result_id" },
        "observation_id": { "$ref": "#/$defs/observation_id" },
        "candidate_fingerprint": { "$ref": "#/$defs/digest" },
        "decision": { "const": "exact_duplicate_noop" }
      }
    },
    "conflict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_result_id",
        "observation_id",
        "code",
        "conflict_fields",
        "existing_fingerprint",
        "incoming_fingerprint",
        "decision"
      ],
      "properties": {
        "record_result_id": { "$ref": "#/$defs/record_result_id" },
        "observation_id": { "$ref": "#/$defs/observation_id" },
        "code": { "const": "source_record_conflict" },
        "conflict_fields": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "uniqueItems": true,
          "items": {
            "enum": [
              "model_tokens.model",
              "model_tokens.input_tokens",
              "model_tokens.output_tokens",
              "model_tokens.total_tokens",
              "model_tokens.cache_tokens",
              "model_tokens.reasoning_tokens",
              "retry_attempt.retry",
              "retry_attempt.attempt",
              "errors.present",
              "errors.code"
            ]
          }
        },
        "existing_fingerprint": { "$ref": "#/$defs/digest" },
        "incoming_fingerprint": { "$ref": "#/$defs/digest" },
        "decision": { "const": "preserve_existing" }
      }
    },
    "retention": {
      "type": "object",
      "additionalProperties": false,
      "required": ["disposition", "created_item_count", "pin_state", "deletion_state"],
      "properties": {
        "disposition": { "const": "not_applicable" },
        "created_item_count": { "const": 0 },
        "pin_state": { "const": "not_applicable" },
        "deletion_state": { "const": "not_applicable" }
      }
    }
  }
}
