{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.copilot-agent-observability.invalid/contracts/historical-import-workflow/v1/import-request.schema.json",
  "title": "Historical import operation request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "schema_version",
    "request_id",
    "idempotency_key",
    "confirmation_id",
    "preview_id",
    "preview_digest",
    "snapshot_version"
  ],
  "properties": {
    "contract_version": { "const": "historical-import-workflow/v1" },
    "schema_version": { "const": "historical-import-workflow-import-request/v1" },
    "request_id": { "type": "string", "minLength": 36, "maxLength": 36, "pattern": "^hir_[0-9a-f]{32}$" },
    "idempotency_key": { "type": "string", "minLength": 36, "maxLength": 36, "pattern": "^hik_[0-9a-f]{32}$" },
    "confirmation_id": { "type": "string", "minLength": 36, "maxLength": 36, "pattern": "^hic_[0-9a-f]{32}$" },
    "preview_id": { "type": "string", "minLength": 36, "maxLength": 36, "pattern": "^hip_[0-9a-f]{32}$" },
    "preview_digest": { "type": "string", "minLength": 71, "maxLength": 71, "pattern": "^sha256:[0-9a-f]{64}$" },
    "snapshot_version": { "type": "string", "minLength": 5, "pattern": "^hsv_[1-9][0-9]*$(?![\\s\\S])" }
  }
}
