{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.copilot-agent-observability.invalid/contracts/historical-import-workflow/v1/observation-list.schema.json",
  "title": "Historical observation list projection",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "schema_version", "source_filter", "items", "next_cursor"],
  "properties": {
    "contract_version": { "const": "historical-import-workflow/v1" },
    "schema_version": { "const": "historical-import-workflow-observation-list/v1" },
    "source_filter": { "const": "historical" },
    "items": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "#/$defs/item" }
    },
    "next_cursor": { "type": ["string", "null"], "minLength": 36, "maxLength": 36, "pattern": "^hoc_[0-9a-f]{32}$" }
  },
  "$defs": {
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observation_id",
        "source_kind",
        "source_surface",
        "source_badge",
        "source_tier",
        "completeness",
        "completeness_reasons",
        "missing_capabilities",
        "content_state",
        "trace_controls_enabled"
      ],
      "properties": {
        "observation_id": { "type": "string", "minLength": 36, "maxLength": 36, "pattern": "^hob_[0-9a-f]{32}$" },
        "source_kind": { "const": "historical" },
        "source_surface": { "enum": ["claude-code", "github-copilot-cli"] },
        "source_badge": { "const": "historical" },
        "source_tier": { "const": "tier_b" },
        "completeness": { "const": "partial" },
        "completeness_reasons": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "uniqueItems": true,
          "items": { "const": "historical_summary_only" }
        },
        "missing_capabilities": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "uniqueItems": true,
          "items": { "enum": ["content", "event_identity", "lifecycle", "session_identity", "timing", "trace_identity"] }
        },
        "content_state": { "const": "not_captured" },
        "trace_controls_enabled": { "const": false }
      }
    }
  }
}
