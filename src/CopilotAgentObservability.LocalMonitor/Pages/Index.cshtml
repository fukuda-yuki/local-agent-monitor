@page "/"
@model IndexModel

<section class="monitor-section">
    <h2>Overview</h2>
    @{
        var statusClass = Model.Readiness.Status switch
        {
            "Healthy" => "success",
            "Degraded" => "warning",
            _ => "error"
        };
    }
    <div class="monitor-metrics">
        <div class="monitor-metric-panel">
            <div class="metric-label">Status</div>
            <div class="metric-value monitor-status @statusClass">@Model.Readiness.Status</div>
        </div>
        <div class="monitor-metric-panel">
            <div class="metric-label">Projection Backlog</div>
            <div class="metric-value">@Model.Readiness.ProjectionBacklog</div>
        </div>
        <div class="monitor-metric-panel">
            <div class="metric-label">Projection Lag</div>
            <div class="metric-value">@(Model.Readiness.ProjectionLagSeconds)s</div>
        </div>
    </div>
</section>

<section class="monitor-section">
    <h2>Recent Ingestions</h2>
    <div class="monitor-table-wrapper">
    <table class="monitor-table">
        <thead>
            <tr>
                <th>RawRecordId</th>
                <th>ReceivedAt</th>
                <th>Source</th>
                <th>TraceId</th>
                <th>ClientKind</th>
                <th class="monitor-text-right">SpanCount</th>
                <th>ProjectedAt</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.RecentIngestions)
            {
                <tr>
                    <td class="monitor-mono">@row.RawRecordId</td>
                    <td>@row.ReceivedAt</td>
                    <td>@row.Source</td>
                    <td><a href="/traces/@row.TraceId">@row.TraceId</a></td>
                    <td>@row.ClientKind</td>
                    <td class="monitor-text-right">@row.SpanCount</td>
                    <td>@row.ProjectedAt</td>
                </tr>
            }
        </tbody>
    </table>
    </div>
</section>
