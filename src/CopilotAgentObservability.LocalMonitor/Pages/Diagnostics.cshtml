@page "/diagnostics"
@model DiagnosticsModel

@{
    var (statusLabel, statusClass) = Model.Readiness.Status switch
    {
        "Healthy" => ("正常", "success"),
        "Degraded" => ("劣化", "warning"),
        _ => ("異常", "error"),
    };
    var degradedReasons = Model.Readiness.DegradedReasons?.ToList() ?? new List<string>();

    string Ok(bool value) => value ? "OK" : "FAIL";
    string OkClass(bool value) => value ? "success" : "error";
}

<section class="monitor-section">
    <h2 class="monitor-page-title">診断</h2>
    <p class="monitor-subtle"><code>GET /health/ready</code> の評価結果</p>

    @if (degradedReasons.Count > 0)
    {
        var bannerClass = Model.Readiness.Status == "Unhealthy" ? "error" : "warning";
        <div class="monitor-banner @bannerClass">
            <strong>@statusLabel:</strong> @string.Join("; ", degradedReasons)
        </div>
    }

    <div class="metric-grid">
        <div class="metric-card metric-card-@statusClass">
            <div class="metric-label">ステータス</div>
            <div class="metric-value monitor-status @statusClass">@statusLabel</div>
        </div>
        <div class="metric-card">
            <div class="metric-label">ループバックバインド</div>
            <div class="metric-value monitor-status @OkClass(Model.Readiness.LoopbackBound)">@(Model.Readiness.LoopbackBound ? "有効" : "無効")</div>
        </div>
        <div class="metric-card">
            <div class="metric-label">プロジェクション遅延</div>
            <div class="metric-value">@(Model.Readiness.ProjectionLagSeconds) 秒</div>
        </div>
        <div class="metric-card">
            <div class="metric-label">プロジェクション残</div>
            <div class="metric-value">@Model.Readiness.ProjectionBacklog</div>
        </div>
    </div>

    <h3 class="monitor-section-title">コンポーネント確認</h3>
    <div class="panel">
        <div class="monitor-table-wrapper">
            <table class="monitor-table">
                <thead>
                    <tr>
                        <th>コンポーネント</th>
                        <th>状態</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>DbOpen</td>
                        <td><span class="monitor-badge @OkClass(Model.Readiness.DbOpen)">@Ok(Model.Readiness.DbOpen)</span></td>
                    </tr>
                    <tr>
                        <td>MigrationComplete</td>
                        <td><span class="monitor-badge @OkClass(Model.Readiness.MigrationComplete)">@Ok(Model.Readiness.MigrationComplete)</span></td>
                    </tr>
                    <tr>
                        <td>WriterRunning</td>
                        <td><span class="monitor-badge @OkClass(Model.Readiness.WriterRunning)">@Ok(Model.Readiness.WriterRunning)</span></td>
                    </tr>
                    <tr>
                        <td>ProjectionWorkerRunning</td>
                        <td><span class="monitor-badge @OkClass(Model.Readiness.ProjectionWorkerRunning)">@Ok(Model.Readiness.ProjectionWorkerRunning)</span></td>
                    </tr>
                    <tr>
                        <td>IngestionAccepting</td>
                        <td><span class="monitor-badge @OkClass(Model.Readiness.IngestionAccepting)">@Ok(Model.Readiness.IngestionAccepting)</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>
