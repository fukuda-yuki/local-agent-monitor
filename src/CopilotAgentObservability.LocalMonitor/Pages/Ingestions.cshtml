@page "/ingestions"
@model IngestionsModel

<section class="monitor-section">
    <h2>Ingestions</h2>
    <div class="monitor-table-wrapper">
    <table class="monitor-table">
        <thead>
            <tr>
                <th>RawRecordId</th>
                <th>ReceivedAt</th>
                <th>Source</th>
                <th>TraceId</th>
                <th>ClientKind</th>
                <th class="monitor-text-right">SpanCount</th>
                <th>ProjectedAt</th>
                @if (Model.RawAvailable)
                {
                    <th>Raw</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Result.Items)
            {
                <tr>
                    <td class="monitor-mono">@row.RawRecordId</td>
                    <td>@row.ReceivedAt</td>
                    <td>@row.Source</td>
                    <td><a href="/traces/@row.TraceId">@row.TraceId</a></td>
                    <td>@row.ClientKind</td>
                    <td class="monitor-text-right">@row.SpanCount</td>
                    <td>@row.ProjectedAt</td>
                    @if (Model.RawAvailable)
                    {
                        <td><a href="/traces/@row.RawRecordId/raw">raw</a></td>
                    }
                </tr>
            }
        </tbody>
    </table>
    </div>
    @if (Model.Result.HasMore && Model.Result.Items.Count > 0)
    {
        <p class="monitor-pagination"><a href="/ingestions?after=@Model.Result.Items[^1].RawRecordId">next →</a></p>
    }
</section>
