<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Local Ingestion Monitor</title>
    <link rel=stylesheet href=/monitor.css />
</head>
<body>
    <header class="monitor-header">
        <nav class="monitor-nav" aria-label="Monitor navigation">
            <span class="monitor-brand">Local Ingestion Monitor</span>
            <a href="/" class="@(Context.Request.Path == "/" ? "active" : "")">Overview</a>
            <a href="/ingestions" class="@(Context.Request.Path.StartsWithSegments("/ingestions") ? "active" : "")">Ingestions</a>
            <a href="/traces" class="@(Context.Request.Path.StartsWithSegments("/traces") ? "active" : "")">Traces</a>
            <a href="/diagnostics" class="@(Context.Request.Path == "/diagnostics" ? "active" : "")">Diagnostics</a>
            <span class="monitor-nav-status" id="monitor-status-dot" title="Checking…" aria-label="Monitor status: checking"></span>
        </nav>
    </header>
    <main class="monitor-content">
        @RenderBody()
    </main>
    <script src=/monitor.js defer></script>
</body>
</html>
