@page "/traces/{traceId}"
@model TraceDetailModel

<section class="monitor-section">
    <p><a href="/traces">&larr; Traces</a></p>
    <h2>Trace <span class="monitor-mono">@Model.TraceId</span></h2>

    @* Sanitized section: tab shell. Summary stays server-rendered; Timeline
       (M4), Flow Chart (M3), and Cache (M5) are filled by JS from the
       sanitized spans API. Tab switching is Vanilla JS (monitor-views.js). *@
    <div class="monitor-tabs tabs" role="tablist" aria-label="Trace views">
        <button class="monitor-tab tab" type="button" role="tab" id="tab-summary" aria-controls="panel-summary" aria-selected="true" tabindex="0">Summary</button>
        <button class="monitor-tab tab" type="button" role="tab" id="tab-timeline" aria-controls="panel-timeline" aria-selected="false" tabindex="-1">Timeline</button>
        <button class="monitor-tab tab" type="button" role="tab" id="tab-flow" aria-controls="panel-flow" aria-selected="false" tabindex="-1">Flow Chart</button>
        <button class="monitor-tab tab" type="button" role="tab" id="tab-cache" aria-controls="panel-cache" aria-selected="false" tabindex="-1">Cache</button>
    </div>

    <div class="monitor-tab-content tab-panel" id="panel-summary" role="tabpanel" aria-labelledby="tab-summary">
        <h3>Summary</h3>
        <div class="monitor-table-wrapper">
        <table class="monitor-table">
            <tbody>
                <tr><th>ClientKind</th><td>@Model.Trace.ClientKind</td></tr>
                <tr><th>Total tool calls</th><td>@Model.Trace.ToolCallCount</td></tr>
                <tr><th>Tokens (input / output / total)</th><td>@Model.Trace.InputTokens / @Model.Trace.OutputTokens / @Model.Trace.TotalTokens</td></tr>
                <tr><th>Error count</th><td>@Model.Trace.ErrorCount</td></tr>
                <tr><th>Duration (ms)</th><td>@Model.Trace.DurationMs</td></tr>
                <tr><th>Turns</th><td>@Model.Trace.TurnCount</td></tr>
                <tr><th>Agent invocations</th><td>@Model.Trace.AgentInvocationCount</td></tr>
                <tr><th>Primary model</th><td>@Model.Trace.PrimaryModel</td></tr>
                <tr><th>Spans</th><td>@Model.Trace.SpanCount</td></tr>
                <tr><th>First / Last seen</th><td>@Model.Trace.FirstSeenAt / @Model.Trace.LastSeenAt</td></tr>
            </tbody>
        </table>
        </div>
    </div>

    <div class="monitor-tab-content tab-panel" id="panel-timeline" role="tabpanel" aria-labelledby="tab-timeline" hidden>
        <h3>Timeline</h3>
        <div class="timeline-toolbar" data-timeline-trace-id="@Model.TraceId">
            <label class="timeline-filter">
                <input id="timeline-errors-only" type="checkbox" />
                Errors only
            </label>
            <fieldset class="segmented-control" aria-label="Timeline sort">
                <legend>Sort</legend>
                <label>
                    <input type="radio" name="timeline-sort" value="time" checked />
                    <span>Time</span>
                </label>
                <label>
                    <input type="radio" name="timeline-sort" value="tokens" />
                    <span>Tokens</span>
                </label>
            </fieldset>
            <span id="timeline-count" class="timeline-count" role="status">Loading spans...</span>
        </div>
        <p id="timeline-empty" class="timeline-empty" hidden>No spans match the current Timeline filter.</p>
        <div class="monitor-table-wrapper table-scroll">
            <table class="monitor-table timeline-table">
                <thead>
                    <tr>
                        <th>Operation</th>
                        <th>Category</th>
                        <th>Tool / MCP / Agent</th>
                        <th>Model</th>
                        <th>Tokens (in / out / total)</th>
                        <th>Status</th>
                        <th>Duration (ms)</th>
                    </tr>
                </thead>
                <tbody id="timeline-rows" data-timeline-trace-id="@Model.TraceId"></tbody>
            </table>
        </div>
    </div>

    <div class="monitor-tab-content tab-panel" id="panel-flow" role="tabpanel" aria-labelledby="tab-flow" hidden>
        <div id="flow-status" class="flow-status" role="status">Loading Flow Chart...</div>
        <div id="flow-chart" class="monitor-flow-chart flow-chart" data-flow-chart-trace-id="@Model.TraceId" aria-label="Trace span flow chart"></div>
    </div>

    <div class="monitor-tab-content tab-panel" id="panel-cache" role="tabpanel" aria-labelledby="tab-cache" hidden>
        <h3>Cache</h3>
        <div id="cache-status" class="cache-status" role="status">Loading Cache Explorer...</div>
        <div id="cache-groups" class="cache-groups" data-cache-trace-id="@Model.TraceId"></div>
    </div>

    @if (Model.RawAvailable)
    {
        <section class="monitor-analysis-panel" data-analysis-trace-id="@Model.TraceId">
            <h3>Analyze raw trace with Copilot</h3>
            <div class="analysis-controls">
                <label for="analysis-focus">Focus</label>
                <select id="analysis-focus">
                    <option value="latency">latency</option>
                    <option value="tokens">tokens</option>
                    <option value="cache">cache</option>
                    <option value="errors">errors</option>
                    <option value="tool-usage">tool-usage</option>
                    <option value="agent-flow">agent-flow</option>
                </select>
                <button id="analysis-start" type="button">Analyze raw trace with Copilot</button>
            </div>
            <pre id="analysis-result" class="monitor-analysis-result" aria-live="polite"></pre>
        </section>
        <script>
            (function () {
                var panel = document.querySelector("[data-analysis-trace-id]");
                if (!panel) return;
                var traceId = panel.getAttribute("data-analysis-trace-id");
                var focus = document.getElementById("analysis-focus");
                var start = document.getElementById("analysis-start");
                var result = document.getElementById("analysis-result");
                start.addEventListener("click", function () {
                    start.disabled = true;
                    result.textContent = "Starting raw analysis...";
                    fetch("/traces/" + encodeURIComponent(traceId) + "/analysis", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            "x-monitor-csrf": "local-monitor"
                        },
                        body: JSON.stringify({ focus: focus.value })
                    })
                        .then(function (response) { return response.json().then(function (body) { return { response: response, body: body }; }); })
                        .then(function (out) {
                            if (!out.response.ok) {
                                result.textContent = "Analysis start failed: " + (out.body.error || out.response.status);
                                return;
                            }

                            result.textContent = "Queued analysis run " + out.body.run_id + ". Waiting for .NET Copilot SDK result...";
                            poll(out.body.run_id);
                        })
                        .catch(function (error) { result.textContent = "Analysis start failed: " + error.message; })
                        .finally(function () { start.disabled = false; });
                });

                function poll(runId) {
                    fetch("/traces/" + encodeURIComponent(traceId) + "/analysis/runs/" + encodeURIComponent(runId))
                        .then(function (response) { return response.json().then(function (body) { return { response: response, body: body }; }); })
                        .then(function (out) {
                            if (!out.response.ok) {
                                result.textContent = "Analysis status failed: " + (out.body.error || out.response.status);
                                return;
                            }

                            if (out.body.status === "queued" || out.body.status === "running") {
                                result.textContent = "Analysis run " + runId + " is " + out.body.status + "...";
                                window.setTimeout(function () { poll(runId); }, 1500);
                                return;
                            }

                            result.textContent = out.body.result_markdown || out.body.error_message || ("Analysis run " + runId + " ended with " + out.body.status + ".");
                        })
                        .catch(function (error) { result.textContent = "Analysis status failed: " + error.message; });
                }
            })();
        </script>

        <h3>Raw OTLP payload</h3>
        @if (Model.RawRecords.Count == 0)
        {
            <p>No raw records for this trace.</p>
        }
        else
        {
            @foreach (var record in Model.RawRecords)
            {
                <h4>Raw record @record.Id</h4>
                <p><a href="/traces/@record.Id/raw">Open full raw record</a> (@record.PayloadLength chars)</p>
                @if (record.IsTruncated)
                {
                    <p>Raw preview truncated.</p>
                }
                <pre class="monitor-raw-preview">@record.Preview</pre>
            }
        }
    }
</section>
