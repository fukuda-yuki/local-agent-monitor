@page "/traces/{traceId}"
@model TraceDetailModel

<section>
    <p><a href="/traces">&larr; Traces</a></p>
    <h2>Trace @Model.TraceId</h2>

    @* Sanitized section: tab shell. Summary stays server-rendered; Timeline
       (M4) and Flow Chart (M3) are filled by JS from the sanitized spans API.
       Cache (M5) remains an empty container filled by JS later.
       Tab switching is Vanilla JS (monitor-views.js). *@
    <div class="tabs" role="tablist" aria-label="Trace views">
        <button class="tab" type="button" role="tab" id="tab-summary" aria-controls="panel-summary" aria-selected="true" tabindex="0">Summary</button>
        <button class="tab" type="button" role="tab" id="tab-timeline" aria-controls="panel-timeline" aria-selected="false" tabindex="-1">Timeline</button>
        <button class="tab" type="button" role="tab" id="tab-flow" aria-controls="panel-flow" aria-selected="false" tabindex="-1">Flow Chart</button>
        <button class="tab" type="button" role="tab" id="tab-cache" aria-controls="panel-cache" aria-selected="false" tabindex="-1">Cache</button>
    </div>

    <div class="tab-panel" id="panel-summary" role="tabpanel" aria-labelledby="tab-summary">
        <h3>Summary</h3>
        <table>
            <tbody>
                <tr><th>ClientKind</th><td>@Model.Trace.ClientKind</td></tr>
                <tr><th>Total tool calls</th><td>@Model.Trace.ToolCallCount</td></tr>
                <tr><th>Tokens (input / output / total)</th><td>@Model.Trace.InputTokens / @Model.Trace.OutputTokens / @Model.Trace.TotalTokens</td></tr>
                <tr><th>Error count</th><td>@Model.Trace.ErrorCount</td></tr>
                <tr><th>Duration (ms)</th><td>@Model.Trace.DurationMs</td></tr>
                <tr><th>Turns</th><td>@Model.Trace.TurnCount</td></tr>
                <tr><th>Agent invocations</th><td>@Model.Trace.AgentInvocationCount</td></tr>
                <tr><th>Primary model</th><td>@Model.Trace.PrimaryModel</td></tr>
                <tr><th>Spans</th><td>@Model.Trace.SpanCount</td></tr>
                <tr><th>First / Last seen</th><td>@Model.Trace.FirstSeenAt / @Model.Trace.LastSeenAt</td></tr>
            </tbody>
        </table>
    </div>

    <div class="tab-panel" id="panel-timeline" role="tabpanel" aria-labelledby="tab-timeline" hidden>
        <h3>Timeline</h3>
        <div class="timeline-toolbar" data-timeline-trace-id="@Model.TraceId">
            <label class="timeline-filter">
                <input id="timeline-errors-only" type="checkbox" />
                Errors only
            </label>
            <fieldset class="segmented-control" aria-label="Timeline sort">
                <legend>Sort</legend>
                <label>
                    <input type="radio" name="timeline-sort" value="time" checked />
                    <span>Time</span>
                </label>
                <label>
                    <input type="radio" name="timeline-sort" value="tokens" />
                    <span>Tokens</span>
                </label>
            </fieldset>
            <span id="timeline-count" class="timeline-count" role="status">Loading spans...</span>
        </div>
        <p id="timeline-empty" class="timeline-empty" hidden>No spans match the current Timeline filter.</p>
        <div class="table-scroll">
            <table class="timeline-table">
                <thead>
                    <tr>
                        <th>Operation</th>
                        <th>Category</th>
                        <th>Tool / MCP / Agent</th>
                        <th>Model</th>
                        <th>Tokens (in / out / total)</th>
                        <th>Status</th>
                        <th>Duration (ms)</th>
                    </tr>
                </thead>
                <tbody id="timeline-rows" data-timeline-trace-id="@Model.TraceId"></tbody>
            </table>
        </div>
    </div>

    <div class="tab-panel" id="panel-flow" role="tabpanel" aria-labelledby="tab-flow" hidden>
        <div id="flow-status" class="flow-status" role="status">Loading Flow Chart...</div>
        <div id="flow-chart" class="flow-chart" data-flow-chart-trace-id="@Model.TraceId" aria-label="Trace span flow chart"></div>
    </div>

    <div class="tab-panel" id="panel-cache" role="tabpanel" aria-labelledby="tab-cache" hidden>
        <p class="tab-placeholder">Cache Explorer is not yet available in this build.</p>
    </div>

    <h3>Raw OTLP payload</h3>
    @if (Model.RawRecords.Count == 0)
    {
        <p>No raw records for this trace.</p>
    }
    else
    {
        @foreach (var record in Model.RawRecords)
        {
            <h4>Raw record @record.Id</h4>
            <p><a href="/traces/@record.Id/raw">Open full raw record</a> (@record.PayloadLength chars)</p>
            @if (record.IsTruncated)
            {
                <p>Raw preview truncated.</p>
            }
            <pre>@record.Preview</pre>
        }
    }
</section>
