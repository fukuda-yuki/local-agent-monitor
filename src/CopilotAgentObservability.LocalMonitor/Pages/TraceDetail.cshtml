@page "/traces/{traceId}"
@model TraceDetailModel
@{
    var title = Model.PromptLabel ?? $"Trace {MonitorViewFormat.ShortTraceId(Model.TraceId)}";
    var spanCount = Model.Trace.SpanCount;
    var hasError = (Model.Trace.ErrorCount ?? 0) > 0;
    var traceStatusLabel = hasError ? "要確認" : "正常";
    var traceStatusClass = hasError ? "error" : "success";
}

<section class="monitor-section trace-detail-page">
    <nav class="breadcrumb" aria-label="パンくず">
        <a href="/">ダッシュボード</a><span class="breadcrumb-sep">›</span>
        <a href="/traces">トレース</a><span class="breadcrumb-sep">›</span>
        <span class="breadcrumb-current">@title</span>
    </nav>

    <div class="trace-hero">
        <div class="trace-hero-main">
            <p class="page-kicker">Trace Detail</p>
            <h2 class="monitor-page-title trace-detail-title">@title</h2>
            <div class="trace-detail-id monitor-mono">TraceId: @Model.TraceId</div>
        </div>
        <div class="trace-health-pill @traceStatusClass">
            <span class="trace-status-dot" aria-hidden="true"></span>
            <span>@traceStatusLabel</span>
        </div>
    </div>

    <div class="metric-grid trace-metric-grid">
        <div class="metric-card metric-card-llm">
            <div class="metric-label">トークン</div>
            <div class="metric-value">@MonitorViewFormat.Tokens(Model.Trace.TotalTokens)</div>
            <div class="metric-sub">入力 @MonitorViewFormat.Tokens(Model.Trace.InputTokens) / 出力 @MonitorViewFormat.Tokens(Model.Trace.OutputTokens)</div>
        </div>
        <div class="metric-card metric-card-accent">
            <div class="metric-label">所要時間</div>
            <div class="metric-value">@MonitorViewFormat.Duration(Model.Trace.DurationMs)</div>
            <div class="metric-sub">@MonitorViewFormat.Count(spanCount) スパン</div>
        </div>
        <div class="metric-card @(hasError ? "metric-card-error" : "metric-card-ok")">
            <div class="metric-label">エラー</div>
            <div class="metric-value">@MonitorViewFormat.Count(Model.Trace.ErrorCount)</div>
            <div class="metric-sub">タイムラインで絞り込み可能</div>
        </div>
        <div class="metric-card metric-card-agent">
            <div class="metric-label">ターン数</div>
            <div class="metric-value">@MonitorViewFormat.Count(Model.Trace.TurnCount)</div>
            <div class="metric-sub">エージェント呼出 @MonitorViewFormat.Count(Model.Trace.AgentInvocationCount)</div>
        </div>
    </div>

    <div class="trace-action-grid" aria-label="このトレースで見る観点">
        <button class="trace-action-card" type="button" data-open-tab="tab-timeline">
            <span class="trace-action-label">失敗と遅延を見る</span>
            <span class="trace-action-copy">span を時刻順または tokens 順で確認</span>
        </button>
        <button class="trace-action-card" type="button" data-open-tab="tab-tree">
            <span class="trace-action-label">実行の流れを見る</span>
            <span class="trace-action-copy">親子関係と waterfall を確認</span>
        </button>
        <button class="trace-action-card" type="button" data-open-tab="tab-cache">
            <span class="trace-action-label">キャッシュを見る</span>
            <span class="trace-action-copy">cache hit rate と token breakdown を確認</span>
        </button>
    </div>

    <div class="monitor-tabs tabs" role="tablist" aria-label="トレースビュー">
        <button class="monitor-tab tab" type="button" role="tab" id="tab-summary" aria-controls="panel-summary" aria-selected="true" tabindex="0">概要</button>
        <button class="monitor-tab tab" type="button" role="tab" id="tab-timeline" aria-controls="panel-timeline" aria-selected="false" tabindex="-1">タイムライン<span class="tab-badge tab-badge-gray">@MonitorViewFormat.Count(spanCount)</span></button>
        <button class="monitor-tab tab" type="button" role="tab" id="tab-tree" aria-controls="panel-tree" aria-selected="false" tabindex="-1">ツリー / フロー<span class="tab-badge tab-badge-blue">@MonitorViewFormat.Count(spanCount)</span></button>
        <button class="monitor-tab tab" type="button" role="tab" id="tab-cache" aria-controls="panel-cache" aria-selected="false" tabindex="-1">キャッシュ</button>
    </div>

    <div class="monitor-tab-content tab-panel" id="panel-summary" role="tabpanel" aria-labelledby="tab-summary">
        <div class="summary-panel">
            <div class="panel-head">
                <span class="panel-title">基本情報</span>
            </div>
            <div class="monitor-table-wrapper">
                <table class="monitor-table">
                    <tbody>
                        <tr><th>クライアント</th><td>@(string.IsNullOrEmpty(Model.Trace.ClientKind) ? "—" : Model.Trace.ClientKind)</td></tr>
                        <tr><th>モデル</th><td>@(string.IsNullOrEmpty(Model.Trace.PrimaryModel) ? "—" : Model.Trace.PrimaryModel)</td></tr>
                        <tr><th>エージェント呼出</th><td>@MonitorViewFormat.Count(Model.Trace.AgentInvocationCount)</td></tr>
                        <tr><th>ツール呼出</th><td>@MonitorViewFormat.Count(Model.Trace.ToolCallCount)</td></tr>
                        <tr><th>スパン数</th><td>@MonitorViewFormat.Count(spanCount)</td></tr>
                        <tr><th>初回 / 最終</th><td>@MonitorViewFormat.RelativeTime(Model.Trace.FirstSeenAt) / @MonitorViewFormat.RelativeTime(Model.Trace.LastSeenAt)</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="monitor-tab-content tab-panel" id="panel-timeline" role="tabpanel" aria-labelledby="tab-timeline" hidden>
        <div class="timeline-toolbar" data-timeline-trace-id="@Model.TraceId">
            <label class="timeline-filter">
                <input id="timeline-errors-only" type="checkbox" />
                エラーのみ
            </label>
            <fieldset class="segmented-control" aria-label="タイムライン並び替え">
                <legend>並び替え</legend>
                <label>
                    <input type="radio" name="timeline-sort" value="time" checked />
                    <span>時刻</span>
                </label>
                <label>
                    <input type="radio" name="timeline-sort" value="tokens" />
                    <span>トークン</span>
                </label>
            </fieldset>
            <span id="timeline-count" class="timeline-count" role="status">スパンを読み込み中…</span>
        </div>
        <p id="timeline-empty" class="timeline-empty empty-state" hidden>フィルター条件に一致するスパンがありません。</p>
        <div class="monitor-table-wrapper table-scroll">
            <table class="monitor-table timeline-table">
                <thead>
                    <tr>
                        <th>操作</th>
                        <th>カテゴリ</th>
                        <th>ツール / MCP / エージェント</th>
                        <th>モデル</th>
                        <th>トークン (入 / 出 / 合計)</th>
                        <th>状態</th>
                        <th>所要時間 (ms)</th>
                    </tr>
                </thead>
                <tbody id="timeline-rows" data-timeline-trace-id="@Model.TraceId"></tbody>
            </table>
        </div>
    </div>

    <div class="monitor-tab-content tab-panel" id="panel-tree" role="tabpanel" aria-labelledby="tab-tree" hidden>
        <div class="view-toolbar">
            <div class="toggle-group" role="group" aria-label="表示切替">
                <button id="view-tree-btn" class="toggle-btn active" type="button" data-view="tree">ツリー</button>
                <button id="view-flow-btn" class="toggle-btn" type="button" data-view="flow">フロー</button>
            </div>
            <div class="view-legend" aria-hidden="true">
                <span class="legend-item"><span class="legend-dot legend-agent"></span>agent</span>
                <span class="legend-item"><span class="legend-dot legend-llm"></span>llm</span>
                <span class="legend-item"><span class="legend-dot legend-tool"></span>tool</span>
                <span class="legend-item"><span class="legend-dot legend-hook"></span>hook</span>
            </div>
        </div>
        <div id="spantree-status" class="spantree-status" role="status">スパンツリーを読み込み中…</div>
        <div id="spantree-view" class="spantree-view" data-spantree-trace-id="@Model.TraceId"></div>
        <div id="flow-view" class="flow-view" hidden></div>
    </div>

    <div class="monitor-tab-content tab-panel" id="panel-cache" role="tabpanel" aria-labelledby="tab-cache" hidden>
        <div id="cache-status" class="cache-status" role="status">キャッシュを読み込み中…</div>
        <div id="cache-groups" class="cache-groups" data-cache-trace-id="@Model.TraceId"></div>
    </div>

    @if (Model.RawAvailable)
    {
        <section class="monitor-analysis-panel" data-analysis-trace-id="@Model.TraceId">
            <div class="panel-head">
                <div>
                    <h3>Copilot raw 解析</h3>
                    <p class="monitor-subtle">選択した trace の raw record をローカルで解析します。</p>
                </div>
            </div>
            <div class="analysis-controls">
                <label for="analysis-focus">解析の観点</label>
                <select id="analysis-focus">
                    <option value="latency">遅延</option>
                    <option value="tokens">トークン</option>
                    <option value="cache">キャッシュ</option>
                    <option value="errors">エラー</option>
                    <option value="tool-usage">ツール利用</option>
                    <option value="agent-flow">エージェントの流れ</option>
                </select>
                <button id="analysis-start" type="button">解析を開始</button>
            </div>
            <pre id="analysis-result" class="monitor-analysis-result" aria-live="polite"></pre>
        </section>
        <script>
            (function () {
                var panel = document.querySelector("[data-analysis-trace-id]");
                if (!panel) return;
                var traceId = panel.getAttribute("data-analysis-trace-id");
                var focus = document.getElementById("analysis-focus");
                var start = document.getElementById("analysis-start");
                var result = document.getElementById("analysis-result");
                start.addEventListener("click", function () {
                    start.disabled = true;
                    result.textContent = "raw 解析を開始しています...";
                    fetch("/traces/" + encodeURIComponent(traceId) + "/analysis", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            "x-monitor-csrf": "local-monitor"
                        },
                        body: JSON.stringify({ focus: focus.value })
                    })
                        .then(function (response) { return response.json().then(function (body) { return { response: response, body: body }; }); })
                        .then(function (out) {
                            if (!out.response.ok) {
                                result.textContent = "解析の開始に失敗しました: " + (out.body.error || out.response.status);
                                return;
                            }

                            result.textContent = "解析 run " + out.body.run_id + " を作成しました。.NET Copilot SDK の結果を待っています...";
                            poll(out.body.run_id);
                        })
                        .catch(function (error) { result.textContent = "解析の開始に失敗しました: " + error.message; })
                        .finally(function () { start.disabled = false; });
                });

                function poll(runId) {
                    fetch("/traces/" + encodeURIComponent(traceId) + "/analysis/runs/" + encodeURIComponent(runId))
                        .then(function (response) { return response.json().then(function (body) { return { response: response, body: body }; }); })
                        .then(function (out) {
                            if (!out.response.ok) {
                                result.textContent = "解析状態の取得に失敗しました: " + (out.body.error || out.response.status);
                                return;
                            }

                            if (out.body.status === "queued" || out.body.status === "running") {
                                result.textContent = "解析 run " + runId + " は " + out.body.status + " です...";
                                window.setTimeout(function () { poll(runId); }, 1500);
                                return;
                            }

                            result.textContent = out.body.result_markdown || out.body.error_message || ("解析 run " + runId + " は " + out.body.status + " で終了しました。");
                        })
                        .catch(function (error) { result.textContent = "解析状態の取得に失敗しました: " + error.message; });
                }
            })();
        </script>

        <details class="raw-section">
            <summary><h3 class="raw-section-title">Raw OTLP ペイロード</h3></summary>
            @if (Model.RawRecords.Count == 0)
            {
                <p class="empty-state">このトレースに raw レコードはありません。</p>
            }
            else
            {
                @foreach (var record in Model.RawRecords)
                {
                    <h4 class="raw-record-title">Raw レコード @record.Id</h4>
                    <p><a href="/traces/@record.Id/raw">完全な raw レコードを開く</a>（@record.PayloadLength 文字）</p>
                    @if (record.IsTruncated)
                    {
                        <p class="monitor-subtle">raw プレビューは省略されています。</p>
                    }
                    <pre class="monitor-raw-preview">@record.Preview</pre>
                }
            }
        </details>
    }
</section>
