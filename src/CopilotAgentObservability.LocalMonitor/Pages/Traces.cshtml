@page "/traces"
@model TracesModel
@{
    string Label(string? traceId) => Model.PromptFor(traceId) ?? MonitorViewFormat.ShortTraceId(traceId);
}

<section class="monitor-section">
    <h2 class="monitor-page-title">トレース一覧</h2>

    <div class="trace-card-list">
        @if (Model.Result.Items.Count == 0)
        {
            <p class="empty-state">まだトレースがありません。</p>
        }
        @foreach (var row in Model.Result.Items)
        {
            var hasError = (row.ErrorCount ?? 0) > 0;
            <a href="/traces/@row.TraceId" class="trace-card @(hasError ? "err" : "ok")">
                <div class="trace-card-main" title="TraceId: @row.TraceId">
                    <div class="trace-card-title">@Label(row.TraceId)</div>
                    <div class="trace-card-sub monitor-mono">@MonitorViewFormat.ShortTraceId(row.TraceId) · @(string.IsNullOrEmpty(row.PrimaryModel) ? "—" : row.PrimaryModel)</div>
                </div>
                <div class="trace-card-chips">
                    <span class="chip"><span class="chip-icon chip-icon-llm">◷</span><span class="monitor-mono">@MonitorViewFormat.Tokens(row.TotalTokens)</span> tok</span>
                    <span class="chip">🔧 <span class="monitor-mono">@MonitorViewFormat.Count(row.ToolCallCount)</span></span>
                    <span class="chip">↻ <span class="monitor-mono">@MonitorViewFormat.Count(row.TurnCount)</span> ターン</span>
                    @if (hasError)
                    {
                        <span class="chip chip-err-on">⚠ @row.ErrorCount エラー</span>
                    }
                    else
                    {
                        <span class="chip chip-muted">エラーなし</span>
                    }
                </div>
            </a>
        }
    </div>

    @if (Model.Result.HasMore && Model.Result.Items.Count > 0)
    {
        <p class="monitor-pagination"><a href="/traces?after=@Model.Result.Items[^1].Id">次へ →</a></p>
    }
</section>
